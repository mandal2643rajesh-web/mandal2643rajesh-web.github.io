<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Rajesh Mandal — Finance & Accounts Executive</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1A1F2E;
  --ink-mid:#2E3547;
  --ink-light:#5A6278;
  --ink-faint:#8E95A6;
  --gold:#8B6914;
  --gold-light:#B8921E;
  --gold-pale:#F9F4E8;
  --rule:#D4C99A;
  --white:#FFFFFF;
  --off-white:#FAFAF7;
  --surface:#F5F4F0;
  --border:#E2DDD4;
  --border-strong:#C8C0B0;
  --font-serif:'Playfair Display',Georgia,serif;
  --font-sans:'Inter',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--font-sans);background:var(--off-white);color:var(--ink);line-height:1.7;overflow-x:hidden}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 5rem;height:64px;
  background:rgba(255,255,255,0.97);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(8px);
}
.nav-brand{display:flex;flex-direction:column;gap:1px}
.nav-name{font-family:var(--font-serif);font-size:1.05rem;font-weight:600;color:var(--ink);letter-spacing:0.01em}
.nav-role{font-size:0.68rem;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-faint)}
.nav-links{display:flex;gap:2.2rem;list-style:none}
.nav-links a{font-size:0.77rem;font-weight:500;letter-spacing:0.07em;text-transform:uppercase;color:var(--ink-light);text-decoration:none;transition:color 0.2s;padding-bottom:2px;border-bottom:1px solid transparent}
.nav-links a:hover{color:var(--gold);border-bottom-color:var(--gold)}

/* ── HERO ── */
#hero{
  min-height:100vh;
  background:var(--ink);
  display:flex;flex-direction:column;justify-content:center;
  padding:9rem 5rem 5rem;
  position:relative;overflow:hidden;
}
.hero-rule{
  width:48px;height:2px;background:var(--rule);
  margin-bottom:2rem;
}
.hero-eyebrow{
  font-size:0.72rem;font-weight:600;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--rule);
  margin-bottom:1.5rem;
}
.hero-name{
  font-family:var(--font-serif);
  font-size:clamp(3.5rem,7vw,6.5rem);
  font-weight:700;line-height:1.0;
  color:var(--white);
  margin-bottom:1.5rem;
  letter-spacing:-0.01em;
}
.hero-headline{
  font-size:1.05rem;font-weight:300;
  color:rgba(255,255,255,0.5);
  max-width:580px;line-height:1.75;
  margin-bottom:3.5rem;
  border-left:2px solid var(--rule);
  padding-left:1.25rem;
}
.hero-meta{
  display:flex;align-items:center;gap:3rem;
  flex-wrap:wrap;margin-bottom:3.5rem;
}
.meta-item{display:flex;flex-direction:column;gap:4px}
.meta-val{font-family:var(--font-serif);font-size:2rem;font-weight:700;color:var(--white);line-height:1}
.meta-key{font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.3)}
.meta-divider{width:1px;height:40px;background:rgba(255,255,255,0.1)}
.hero-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
.btn-solid{
  font-family:var(--font-sans);font-size:0.78rem;font-weight:600;
  letter-spacing:0.1em;text-transform:uppercase;
  background:var(--white);color:var(--ink);
  border:none;padding:0.85rem 2rem;
  cursor:pointer;text-decoration:none;display:inline-block;
  transition:background 0.2s,transform 0.15s;
}
.btn-solid:hover{background:#F0EEE8;transform:translateY(-1px)}
.btn-ghost{
  font-family:var(--font-sans);font-size:0.78rem;font-weight:500;
  letter-spacing:0.1em;text-transform:uppercase;
  background:transparent;color:rgba(255,255,255,0.6);
  border:1px solid rgba(255,255,255,0.2);padding:0.85rem 2rem;
  cursor:pointer;text-decoration:none;display:inline-block;
  transition:border-color 0.2s,color 0.2s;
}
.btn-ghost:hover{border-color:var(--rule);color:var(--rule)}
.hero-contact-strip{
  position:absolute;bottom:0;left:0;right:0;
  display:flex;border-top:1px solid rgba(255,255,255,0.07);
}
.strip-item{
  flex:1;display:flex;align-items:center;gap:0.75rem;
  padding:1.1rem 5rem;
  font-size:0.8rem;color:rgba(255,255,255,0.4);
  border-right:1px solid rgba(255,255,255,0.07);
  text-decoration:none;transition:color 0.2s,background 0.2s;
}
.strip-item:last-child{border-right:none}
.strip-item:hover{color:var(--rule);background:rgba(255,255,255,0.03)}
.strip-icon{font-size:0.9rem;flex-shrink:0}

/* ── SECTION COMMON ── */
section{padding:5.5rem 5rem}
.sec-header{margin-bottom:3.5rem}
.sec-eyebrow{
  font-size:0.68rem;font-weight:600;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;
}
.sec-eyebrow::after{content:'';flex:1;height:1px;background:var(--border);max-width:48px}
.sec-title{
  font-family:var(--font-serif);
  font-size:clamp(1.8rem,3.5vw,2.6rem);
  font-weight:700;color:var(--ink);line-height:1.2;
}
.sec-title em{font-style:normal;color:var(--gold)}

/* ── ABOUT ── */
#about{background:var(--white)}
.about-layout{display:grid;grid-template-columns:1fr 360px;gap:6rem;align-items:start}
.about-text p{font-size:0.97rem;color:var(--ink-mid);line-height:1.9;margin-bottom:1.1rem}
.about-text p:last-child{margin-bottom:0}
.about-sidebar{display:flex;flex-direction:column;gap:0}
.sidebar-block{padding:1.25rem 0;border-bottom:1px solid var(--border)}
.sidebar-block:first-child{padding-top:0}
.sidebar-block:last-child{border-bottom:none;padding-bottom:0}
.sidebar-label{
  font-size:0.65rem;font-weight:700;letter-spacing:0.16em;
  text-transform:uppercase;color:var(--ink-faint);margin-bottom:0.5rem;
}
.sidebar-val{font-size:0.88rem;font-weight:500;color:var(--ink);line-height:1.5}
.sidebar-val small{display:block;font-weight:400;color:var(--ink-light);font-size:0.8rem;margin-top:2px}

/* ── EXPERIENCE ── */
#experience{background:var(--off-white)}
.exp-list{display:flex;flex-direction:column;gap:0}
.exp-card{
  display:grid;grid-template-columns:200px 1fr;
  gap:0 3rem;padding:2.5rem 0;
  border-bottom:1px solid var(--border);
}
.exp-card:first-child{border-top:1px solid var(--border)}
.exp-left{padding-top:0.15rem}
.exp-period-tag{
  font-size:0.7rem;font-weight:600;letter-spacing:0.1em;
  text-transform:uppercase;color:var(--gold);
  background:var(--gold-pale);
  padding:0.3rem 0.65rem;display:inline-block;
  margin-bottom:0.75rem;
}
.exp-co-name{font-size:0.82rem;font-weight:600;color:var(--ink-mid);line-height:1.4}
.exp-sector{font-size:0.75rem;color:var(--ink-faint);margin-top:2px}
.exp-right{}
.exp-role-title{
  font-family:var(--font-serif);
  font-size:1.2rem;font-weight:700;color:var(--ink);
  margin-bottom:1.1rem;
}
.exp-points{list-style:none;display:flex;flex-direction:column;gap:0.55rem}
.exp-points li{
  font-size:0.88rem;color:var(--ink-light);line-height:1.7;
  padding-left:1.1rem;position:relative;
}
.exp-points li::before{
  content:'';position:absolute;left:0;top:0.6em;
  width:4px;height:4px;background:var(--border-strong);border-radius:50%;
}

/* ── SKILLS ── */
#skills{background:var(--white)}
.skills-layout{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--border)}
.skill-block{padding:2rem 1.75rem;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.skill-block:nth-child(3n){border-right:none}
.skill-block:nth-child(n+4){border-bottom:none}
.skill-block-label{
  font-size:0.65rem;font-weight:700;letter-spacing:0.16em;
  text-transform:uppercase;color:var(--ink-faint);
  margin-bottom:1rem;padding-bottom:0.75rem;
  border-bottom:1px solid var(--border);
}
.skill-list{display:flex;flex-wrap:wrap;gap:0.4rem}
.skill-pill{
  font-size:0.77rem;font-weight:400;color:var(--ink-mid);
  background:var(--surface);border:1px solid var(--border);
  padding:0.25rem 0.65rem;
}

/* ── ACHIEVEMENTS ── */
#projects{background:var(--off-white)}
.ach-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.ach-card{
  background:var(--white);border:1px solid var(--border);
  padding:2rem 1.75rem;
  position:relative;
  transition:border-color 0.2s,box-shadow 0.2s;
}
.ach-card:hover{border-color:var(--border-strong);box-shadow:0 4px 20px rgba(26,31,46,0.06)}
.ach-index{
  font-family:var(--font-serif);
  font-size:0.75rem;font-weight:600;color:var(--ink-faint);
  letter-spacing:0.1em;margin-bottom:1rem;
}
.ach-title{
  font-family:var(--font-serif);
  font-size:1.05rem;font-weight:700;color:var(--ink);
  margin-bottom:0.65rem;line-height:1.35;
}
.ach-body{font-size:0.85rem;color:var(--ink-light);line-height:1.75;margin-bottom:1.25rem}
.ach-kpi{
  display:inline-flex;align-items:center;gap:0.5rem;
  font-size:0.7rem;font-weight:700;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--gold);
  background:var(--gold-pale);
  padding:0.35rem 0.75rem;
  border-left:2px solid var(--gold);
}

/* ── EDUCATION ── */
#education{background:var(--white)}
.edu-table{width:100%;border-collapse:collapse;margin-top:0.5rem}
.edu-table th{
  font-size:0.65rem;font-weight:700;letter-spacing:0.16em;
  text-transform:uppercase;color:var(--ink-faint);
  text-align:left;padding:0 1.5rem 1rem 0;
  border-bottom:1px solid var(--border-strong);
}
.edu-table td{
  font-size:0.88rem;color:var(--ink-mid);
  padding:1.1rem 1.5rem 1.1rem 0;
  border-bottom:1px solid var(--border);
  vertical-align:top;
}
.edu-table tr:last-child td{border-bottom:none}
.edu-deg{font-weight:600;color:var(--ink);font-size:0.92rem}
.badge{
  display:inline-block;font-size:0.65rem;font-weight:600;
  letter-spacing:0.09em;text-transform:uppercase;
  padding:0.2rem 0.55rem;
}
.badge-done{background:#EBF5EB;color:#1F6B2E}
.badge-prog{background:var(--gold-pale);color:var(--gold)}

/* ── CONTACT ── */
#contact{background:var(--ink)}
#contact .sec-title{color:var(--white)}
#contact .sec-eyebrow{color:var(--rule)}
#contact .sec-eyebrow::after{background:rgba(255,255,255,0.15)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start}
.contact-desc{font-size:0.97rem;color:rgba(255,255,255,0.45);line-height:1.85;margin-top:1.5rem}
.contact-details{display:flex;flex-direction:column;gap:0}
.cdet-row{
  display:flex;align-items:flex-start;gap:1.25rem;
  padding:1.25rem 0;border-bottom:1px solid rgba(255,255,255,0.07);
  text-decoration:none;color:inherit;
  transition:color 0.2s;
}
.cdet-row:last-child{border-bottom:none}
.cdet-row:hover .cdet-val{color:var(--rule)}
.cdet-icon{font-size:1rem;color:rgba(255,255,255,0.25);padding-top:2px;flex-shrink:0}
.cdet-group{display:flex;flex-direction:column;gap:2px}
.cdet-key{font-size:0.65rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.25)}
.cdet-val{font-size:0.9rem;font-weight:400;color:rgba(255,255,255,0.7);transition:color 0.2s}

footer{
  background:#111620;
  text-align:center;padding:1.25rem 5rem;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(255,255,255,0.05);
}
.footer-name{font-family:var(--font-serif);font-size:0.85rem;font-weight:600;color:rgba(255,255,255,0.3)}
.footer-copy{font-size:0.72rem;color:rgba(255,255,255,0.2);letter-spacing:0.06em}

@media(max-width:900px){
  nav{padding:0 1.5rem}
  #hero{padding:7rem 1.5rem 5rem}
  .hero-contact-strip .strip-item{padding:1rem 1.5rem}
  section{padding:4rem 1.5rem}
  .about-layout{grid-template-columns:1fr;gap:2.5rem}
  .exp-card{grid-template-columns:1fr;gap:0.75rem}
  .skills-layout{grid-template-columns:1fr 1fr}
  .skill-block:nth-child(3n){border-right:1px solid var(--border)}
  .skill-block:nth-child(2n){border-right:none}
  .skill-block:nth-child(n+5){border-bottom:none}
  .ach-grid{grid-template-columns:1fr}
  .contact-grid{grid-template-columns:1fr;gap:2.5rem}
  footer{flex-direction:column;gap:0.5rem}
}
</style>
</head>
